 657:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****  ===============================================================================
 658:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****                       ##### IO operation functions #####
ARM GAS  /tmp/ccxIcsF9.s 			page 13


 659:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****  ===============================================================================
 660:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****     [..] This subsection provides a set of functions allowing to manage the USART synchronous SPI
 661:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****     data transfers.
 662:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c **** 
 663:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****     [..] The USART Synchronous SPI supports master and slave modes (SCLK as output or input).
 664:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c **** 
 665:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****     [..]
 666:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c **** 
 667:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****     (#) There are two modes of transfer:
 668:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) Blocking mode: The communication is performed in polling mode.
 669:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****              The HAL status of all data processing is returned by the same function
 670:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****              after finishing transfer.
 671:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) No-Blocking mode: The communication is performed using Interrupts
 672:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****              or DMA, These API's return the HAL status.
 673:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****              The end of the data processing will be indicated through the
 674:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****              dedicated USART IRQ when using Interrupt mode or the DMA IRQ when
 675:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****              using DMA mode.
 676:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****              The HAL_USART_TxCpltCallback(), HAL_USART_RxCpltCallback() and HAL_USART_TxRxCpltCallb
 677:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****              will be executed respectively at the end of the transmit or Receive process
 678:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****              The HAL_USART_ErrorCallback()user callback will be executed when a communication error
 679:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c **** 
 680:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****     (#) Blocking mode API's are :
 681:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_Transmit() in simplex mode
 682:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_Receive() in full duplex receive only
 683:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_TransmitReceive() in full duplex mode
 684:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c **** 
 685:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****     (#) Non-Blocking mode API's with Interrupt are :
 686:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_Transmit_IT() in simplex mode
 687:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_Receive_IT() in full duplex receive only
 688:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_TransmitReceive_IT() in full duplex mode
 689:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_IRQHandler()
 690:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c **** 
 691:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****     (#) No-Blocking mode API's  with DMA are :
 692:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_Transmit_DMA() in simplex mode
 693:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_Receive_DMA() in full duplex receive only
 694:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_TransmitReceive_DMA() in full duplex mode
 695:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_DMAPause()
 696:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_DMAResume()
 697:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_DMAStop()
 698:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c **** 
 699:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****     (#) A set of Transfer Complete Callbacks are provided in Non_Blocking mode:
 700:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_TxCpltCallback()
 701:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_RxCpltCallback()
 702:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_TxHalfCpltCallback()
 703:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_RxHalfCpltCallback()
 704:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_ErrorCallback()
 705:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_TxRxCpltCallback()
 706:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c **** 
 707:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****     (#) Non-Blocking mode transfers could be aborted using Abort API's :
 708:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_Abort()
 709:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_Abort_IT()
 710:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c **** 
 711:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****     (#) For Abort services based on interrupts (HAL_USART_Abort_IT), a Abort Complete Callbacks is 
 712:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) HAL_USART_AbortCpltCallback()
 713:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c **** 
 714:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****     (#) In Non-Blocking mode transfers, possible errors are split into 2 categories.
 715:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         Errors are handled as follows :
ARM GAS  /tmp/ccxIcsF9.s 			page 14


 716:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****         (++) Error is considered as Recoverable and non blocking : Transfer could go till end, but 
 717:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****              to be evaluated by user : this concerns Frame Error,
 718:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****              Parity Error or Noise Error in Interrupt mode reception .
 719:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****              Received character is then retrieved and stored in Rx buffer, Error code is set to all
 720:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_usart.c ****              error type, and HAL_USART_ErrorCallback() user callback is executed.
